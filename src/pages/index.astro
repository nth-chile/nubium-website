---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';

---

<Layout>
  <div class="fixed inset-0 -z-10 bg-[radial-gradient(ellipse_120%_70%_at_50%_120%,rgba(15,50,120,0.55),transparent_55%),radial-gradient(ellipse_90%_50%_at_25%_105%,rgba(20,40,90,0.4),transparent_45%),radial-gradient(ellipse_80%_45%_at_75%_95%,rgba(10,35,80,0.35),transparent_50%)]"></div>
  <Nav />

  <!-- Hero -->
  <section class="pt-32 pb-20 px-6">
    <div class="mx-auto max-w-4xl text-center">
      <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight leading-[1.1]">
        Free, open-source<br />music notation.
      </h1>
      <p class="mt-6 text-lg md:text-xl text-[var(--color-text-muted)] max-w-2xl mx-auto">
        Runs on your desktop or in the browser. Extend it with community plugins, AI editing tools, or write your own.
      </p>
      <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-6">
        <a href="https://app.nubium.rocks" target="_blank" rel="noopener noreferrer" class="px-8 py-3.5 rounded-xl bg-[var(--color-accent)] hover:bg-[var(--color-accent-hover)] text-white font-semibold text-lg transition-colors no-underline">
          Try in Browser
        </a>
        <a href="/download" id="hero-download" class="text-[var(--color-accent)] hover:text-[var(--color-accent-hover)] font-medium text-lg transition-colors no-underline">
          Download for desktop
        </a>
      </div>
    </div>
  </section>

  <!-- App Screenshot -->
  <section class="px-6 pb-24">
    <div class="mx-auto max-w-5xl">
      <div class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg-card)] overflow-hidden">
        <img src="/screenshot.png" alt="Nubium music notation editor showing a score called Sea of Clouds" class="w-full h-auto block" />
      </div>
    </div>
  </section>

  <!-- Three Pillars -->
  <section class="px-6 pb-32">
    <div class="mx-auto max-w-3xl space-y-12">
      <div>
        <h3 class="text-xl font-semibold mb-2">Fully featured</h3>
        <p class="text-[var(--color-text-muted)] leading-relaxed">
          MIDI input, guitar tabs, AI editing, four independent voices, flexible input modes, export to PDF or audio, and more. We're in beta and adding features fast — tell us what you need.
        </p>
      </div>
      <div>
        <h3 class="text-xl font-semibold mb-2">Works with all standard formats</h3>
        <p class="text-[var(--color-text-muted)] leading-relaxed">
          Nubium uses MusicXML as its file format, so your scores are compatible with almost all other tools. Paste tabs, LilyPond, or ABC notation onto a score and see it instantly render. Select notes and copy as any text-based format.
        </p>
      </div>
      <div>
        <h3 class="text-xl font-semibold mb-2">Configure your workspace</h3>
        <p class="text-[var(--color-text-muted)] leading-relaxed">
          Plugin-based architecture and drag-and-drop UI panels. Turn off what you don't need, find or build plugins for what you do.
        </p>
      </div>
    </div>
  </section>

  <!-- Features Grid -->
  <section class="px-6 pb-32">
    <div class="mx-auto max-w-5xl">
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight mb-12 text-center">Features</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        <div class="p-6 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-subtle)]">
          <i class="ri-list-settings-fill text-2xl text-[var(--color-accent)] mb-3 block"></i>
          <h3 class="font-semibold mb-1">Input modes</h3>
          <p class="text-sm text-[var(--color-text-muted)]">Pitch-before-duration, insert mode, or standard entry. Work however you prefer.</p>
        </div>
        <div class="p-6 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-subtle)]">
          <i class="ri-sparkling-fill text-2xl text-[var(--color-accent)] mb-3 block"></i>
          <h3 class="font-semibold mb-1">AI editing</h3>
          <p class="text-sm text-[var(--color-text-muted)]">Edit your score with natural language. Bring your own API key.</p>
        </div>
        <div class="p-6 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-subtle)]">
          <i class="fa-solid fa-guitar text-2xl text-[var(--color-accent)] mb-3 block"></i>
          <h3 class="font-semibold mb-1">Guitar tablature</h3>
          <p class="text-sm text-[var(--color-text-muted)]">Full tab support with a wide range of guitar-specific articulations and techniques.</p>
        </div>
        <div class="p-6 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-subtle)]">
          <i class="ri-keyboard-fill text-2xl text-[var(--color-accent)] mb-3 block"></i>
          <h3 class="font-semibold mb-1">MIDI input</h3>
          <p class="text-sm text-[var(--color-text-muted)]">Step entry from any MIDI controller.</p>
        </div>
        <div class="p-6 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-subtle)]">
          <i class="ri-puzzle-fill text-2xl text-[var(--color-accent)] mb-3 block"></i>
          <h3 class="font-semibold mb-1">Plugins & configuration</h3>
          <p class="text-sm text-[var(--color-text-muted)]">Install community plugins or write your own. Customize keybindings, settings, and layout.</p>
        </div>
        <div class="p-6 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-subtle)]">
          <i class="ri-music-2-fill text-2xl text-[var(--color-accent)] mb-3 block"></i>
          <h3 class="font-semibold mb-1">4 independent voices</h3>
          <p class="text-sm text-[var(--color-text-muted)]">Four voices per measure with a color-coded cursor so you always know which voice you're editing.</p>
        </div>
        <div class="p-6 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-subtle)]">
          <i class="ri-terminal-box-fill text-2xl text-[var(--color-accent)] mb-3 block"></i>
          <h3 class="font-semibold mb-1">Command palette</h3>
          <p class="text-sm text-[var(--color-text-muted)]">Search and run any command without leaving the keyboard.</p>
        </div>
        <div class="p-6 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-subtle)]">
          <i class="ri-clipboard-fill text-2xl text-[var(--color-accent)] mb-3 block"></i>
          <h3 class="font-semibold mb-1">Paste & copy as</h3>
          <p class="text-sm text-[var(--color-text-muted)]">Paste guitar tabs, LilyPond, or ABC directly onto the sheet and see it instantly render. Select notes and copy as any format.</p>
        </div>
        <div class="p-6 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-subtle)]">
          <i class="ri-history-fill text-2xl text-[var(--color-accent)] mb-3 block"></i>
          <h3 class="font-semibold mb-1">File history</h3>
          <p class="text-sm text-[var(--color-text-muted)]">Automatic snapshots of your score. Go back to a previous version anytime.</p>
        </div>
        <div class="p-6 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-subtle)]">
          <i class="ri-file-download-fill text-2xl text-[var(--color-accent)] mb-3 block"></i>
          <h3 class="font-semibold mb-1">Export to PDF & audio</h3>
          <p class="text-sm text-[var(--color-text-muted)]">Print-ready PDFs and WAV audio export.</p>
        </div>
        <div class="p-6 rounded-xl border border-dashed border-[var(--color-border)] bg-[var(--color-bg-subtle)]">
          <i class="ri-lightbulb-fill text-2xl text-[var(--color-accent)] mb-3 block"></i>
          <h3 class="font-semibold mb-1">Your feature here</h3>
          <p class="text-sm text-[var(--color-text-muted)] mb-3">Tell us what you need.</p>
          <form action="https://formspree.io/f/xgopavpe" method="POST" class="space-y-2" id="homepage-suggest-form">
            <textarea name="message" required rows="2" placeholder="I wish Nubium could…" class="w-full px-3 py-2 rounded-lg border border-[var(--color-border)] bg-[var(--color-bg)] text-[var(--color-text)] placeholder-[var(--color-text-muted)] resize-none focus:outline-none focus:border-[var(--color-accent)] transition-colors text-xs"></textarea>
            <button type="submit" class="w-full px-3 py-1.5 rounded-lg bg-[var(--color-accent)] hover:bg-[var(--color-accent-hover)] text-white font-medium text-xs transition-colors cursor-pointer">Send</button>
          </form>
          <p id="homepage-suggest-thanks" class="text-sm text-[var(--color-text-muted)] hidden">Thanks! We'll take a look.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="px-6 pb-32">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight">Try Nubium</h2>
      <p class="mt-4 text-[var(--color-text-muted)] text-lg">
        Nubium is free. No account required.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-6">
        <a href="https://app.nubium.rocks" target="_blank" rel="noopener noreferrer" class="px-8 py-3.5 rounded-xl bg-[var(--color-accent)] hover:bg-[var(--color-accent-hover)] text-white font-semibold text-lg transition-colors no-underline">
          Try in Browser
        </a>
        <a href="/download" id="cta-download" class="text-[var(--color-accent)] hover:text-[var(--color-accent-hover)] font-medium text-lg transition-colors no-underline">
          Download for desktop
        </a>
      </div>
    </div>
  </section>

  <!-- Quick Links -->
  <section class="px-6 pb-32">
    <div class="mx-auto max-w-5xl grid sm:grid-cols-3 gap-8">
      <a href="/help" class="p-8 rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg-subtle)] hover:border-[var(--color-text-muted)] transition-colors no-underline group text-center">
        <h3 class="text-xl font-semibold group-hover:text-[var(--color-accent)] transition-colors">Help docs</h3>
        <p class="mt-2 text-sm text-[var(--color-text-muted)]">Learn how to use Nubium.</p>
      </a>
      <a href="/roadmap" class="p-8 rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg-subtle)] hover:border-[var(--color-text-muted)] transition-colors no-underline group text-center">
        <h3 class="text-xl font-semibold group-hover:text-[var(--color-accent)] transition-colors">Roadmap</h3>
        <p class="mt-2 text-sm text-[var(--color-text-muted)]">See what we're working on.</p>
      </a>
      <a href="/community" class="p-8 rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg-subtle)] hover:border-[var(--color-text-muted)] transition-colors no-underline group text-center">
        <h3 class="text-xl font-semibold group-hover:text-[var(--color-accent)] transition-colors">Community</h3>
        <p class="mt-2 text-sm text-[var(--color-text-muted)]">Connect with other users.</p>
      </a>
    </div>
  </section>

</Layout>

<script>
  const REPO = 'nth-chile/nubium';

  function detectPlatform(): { os: string; asset: string } {
    const ua = navigator.userAgent.toLowerCase();
    const plat = (navigator as any).userAgentData?.platform?.toLowerCase() ?? navigator.platform?.toLowerCase() ?? '';

    if (plat.includes('mac') || ua.includes('macintosh')) {
      try {
        const canvas = document.createElement('canvas');
        const gl = canvas.getContext('webgl');
        if (gl) {
          const ext = gl.getExtension('WEBGL_debug_renderer_info');
          if (ext) {
            const renderer = gl.getParameter(ext.UNMASKED_RENDERER_WEBGL);
            if (renderer && renderer.includes('Apple')) {
              return { os: 'macOS', asset: 'aarch64.dmg' };
            }
          }
        }
      } catch {}
      return { os: 'macOS', asset: 'x64.dmg' };
    }
    if (plat.includes('win') || ua.includes('windows')) return { os: 'Windows', asset: 'x64-setup.exe' };
    if (plat.includes('linux') || ua.includes('linux')) return { os: 'Linux', asset: '.AppImage' };
    return { os: '', asset: '' };
  }

  const { os, asset } = detectPlatform();

  // Update button text
  if (os) {
    document.querySelectorAll('#hero-download, #cta-download').forEach(el => {
      el.textContent = `Get Nubium for ${os}`;
    });
  }

  // Resolve direct download URL from GitHub Releases
  if (asset) {
    fetch(`https://api.github.com/repos/${REPO}/releases/latest`)
      .then(r => r.ok ? r.json() : null)
      .then(release => {
        if (!release) return;
        const match = release.assets.find((a: any) =>
          a.name.includes(asset) && !a.name.endsWith('.sig') && !a.name.endsWith('.json')
        );
        if (match) {
          document.querySelectorAll<HTMLAnchorElement>('#hero-download, #cta-download').forEach(el => {
            el.href = match.browser_download_url;
          });
        }
      })
      .catch(() => {});
  }

  const hForm = document.getElementById('homepage-suggest-form') as HTMLFormElement;
  const hThanks = document.getElementById('homepage-suggest-thanks')!;

  hForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = new FormData(hForm);
    try {
      await fetch(hForm.action, { method: 'POST', body: data, headers: { Accept: 'application/json' } });
      hForm.classList.add('hidden');
      hThanks.classList.remove('hidden');
    } catch {
      hForm.submit();
    }
  });
</script>
