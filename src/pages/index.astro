---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';

---

<Layout>
  <div class="fixed inset-0 -z-10 bg-[radial-gradient(ellipse_120%_70%_at_50%_120%,rgba(15,50,120,0.55),transparent_55%),radial-gradient(ellipse_90%_50%_at_25%_105%,rgba(20,40,90,0.4),transparent_45%),radial-gradient(ellipse_80%_45%_at_75%_95%,rgba(10,35,80,0.35),transparent_50%)]"></div>
  <Nav />

  <!-- Hero -->
  <section class="pt-32 pb-20 px-6">
    <div class="mx-auto max-w-4xl text-center">
      <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight leading-[1.1]">
        Write music,<br />not markup.
      </h1>
      <p class="mt-6 text-lg md:text-xl text-[var(--color-text-muted)] max-w-2xl mx-auto">
        Free, fast notation software that stays out of your way. Open formats, extensible with plugins, runs on your machine.
      </p>
      <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-6">
        <a href="https://app.nubium.rocks" class="px-8 py-3.5 rounded-xl bg-[var(--color-accent)] hover:bg-[var(--color-accent-hover)] text-white font-semibold text-lg transition-colors no-underline">
          Try in Browser
        </a>
        <a href="/download" id="hero-download" class="text-[var(--color-accent)] hover:text-[var(--color-accent-hover)] font-medium text-lg transition-colors no-underline">
          Download for desktop
        </a>
      </div>
    </div>
  </section>

  <!-- App Screenshot -->
  <section class="px-6 pb-24">
    <div class="mx-auto max-w-5xl">
      <div class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg-card)] overflow-hidden aspect-[16/10] flex items-center justify-center">
        <p class="text-[var(--color-text-muted)] text-sm">App screenshot placeholder</p>
      </div>
    </div>
  </section>

  <!-- Three Pillars -->
  <section class="px-6 pb-32">
    <div class="mx-auto max-w-3xl space-y-12">
      <div>
        <h3 class="text-xl font-semibold mb-2">Fast and local.</h3>
        <p class="text-[var(--color-text-muted)] leading-relaxed">
          Nubium runs on your machine, not in a browser tab. Instant startup, no loading spinners, no account required. Your files stay on your disk.
        </p>
      </div>
      <div>
        <h3 class="text-xl font-semibold mb-2">Open formats.</h3>
        <p class="text-[var(--color-text-muted)] leading-relaxed">
          Import and export MusicXML. Your scores work with MuseScore, Dorico, Sibelius, and anything else that speaks MusicXML. No lock-in, ever.
        </p>
      </div>
      <div>
        <h3 class="text-xl font-semibold mb-2">Make it yours.</h3>
        <p class="text-[var(--color-text-muted)] leading-relaxed">
          Extend Nubium with plugins. Transpose, analyze chords, export PDF, connect MIDI controllers — or build your own plugin.
        </p>
      </div>
    </div>
  </section>

  <!-- Features Grid -->
  <section class="px-6 pb-32">
    <div class="mx-auto max-w-5xl">
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight mb-12 text-center">Everything you need.</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        <div class="p-6 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-subtle)]">
          <i class="ri-piano-fill text-2xl text-[var(--color-accent)] mb-3 block"></i>
          <h3 class="font-semibold mb-1">MIDI input</h3>
          <p class="text-sm text-[var(--color-text-muted)]">Step entry or real-time recording from any MIDI controller.</p>
        </div>
        <div class="p-6 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-subtle)]">
          <i class="ri-music-2-fill text-2xl text-[var(--color-accent)] mb-3 block"></i>
          <h3 class="font-semibold mb-1">Multiple voices</h3>
          <p class="text-sm text-[var(--color-text-muted)]">Independent voices per staff with cross-staff notation.</p>
        </div>
        <div class="p-6 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-subtle)]">
          <i class="ri-hashtag text-2xl text-[var(--color-accent)] mb-3 block"></i>
          <h3 class="font-semibold mb-1">Chord symbols & tab</h3>
          <p class="text-sm text-[var(--color-text-muted)]">Chord symbols and guitar tablature.</p>
        </div>
        <div class="p-6 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-subtle)]">
          <i class="ri-play-circle-fill text-2xl text-[var(--color-accent)] mb-3 block"></i>
          <h3 class="font-semibold mb-1">Playback</h3>
          <p class="text-sm text-[var(--color-text-muted)]">Hear your score with swing, shuffle, repeats, D.S., and codas.</p>
        </div>
        <div class="p-6 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-subtle)]">
          <i class="ri-text text-2xl text-[var(--color-accent)] mb-3 block"></i>
          <h3 class="font-semibold mb-1">Lyrics & dynamics</h3>
          <p class="text-sm text-[var(--color-text-muted)]">Full support for lyrics, dynamics, articulations, and expressions.</p>
        </div>
        <div class="p-6 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-subtle)]">
          <i class="ri-arrow-up-down-fill text-2xl text-[var(--color-accent)] mb-3 block"></i>
          <h3 class="font-semibold mb-1">Transposition</h3>
          <p class="text-sm text-[var(--color-text-muted)]">Transpose instantly. Extract individual parts from a full score.</p>
        </div>
        <div class="p-6 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-subtle)]">
          <i class="ri-file-pdf-2-fill text-2xl text-[var(--color-accent)] mb-3 block"></i>
          <h3 class="font-semibold mb-1">PDF & MusicXML export</h3>
          <p class="text-sm text-[var(--color-text-muted)]">Export to PDF for print or MusicXML for any other notation app.</p>
        </div>
        <div class="p-6 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-subtle)]">
          <i class="ri-puzzle-fill text-2xl text-[var(--color-accent)] mb-3 block"></i>
          <h3 class="font-semibold mb-1">Plugins</h3>
          <p class="text-sm text-[var(--color-text-muted)]">Extend Nubium with community plugins or build your own.</p>
        </div>
        <div class="p-6 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-subtle)]">
          <i class="ri-computer-fill text-2xl text-[var(--color-accent)] mb-3 block"></i>
          <h3 class="font-semibold mb-1">Cross-platform</h3>
          <p class="text-sm text-[var(--color-text-muted)]">Runs natively on macOS, Windows, and Linux.</p>
        </div>
        <div class="p-6 rounded-xl border border-dashed border-[var(--color-border)] bg-[var(--color-bg-subtle)]">
          <i class="ri-lightbulb-fill text-2xl text-[var(--color-accent)] mb-3 block"></i>
          <h3 class="font-semibold mb-1">Your feature here</h3>
          <p class="text-sm text-[var(--color-text-muted)] mb-3">Tell us what you need — no account required.</p>
          <form action="https://formspree.io/f/xgopavpe" method="POST" class="space-y-2" id="homepage-suggest-form">
            <textarea name="message" required rows="2" placeholder="I wish Nubium could…" class="w-full px-3 py-2 rounded-lg border border-[var(--color-border)] bg-[var(--color-bg)] text-[var(--color-text)] placeholder-[var(--color-text-muted)] resize-none focus:outline-none focus:border-[var(--color-accent)] transition-colors text-xs"></textarea>
            <button type="submit" class="w-full px-3 py-1.5 rounded-lg bg-[var(--color-accent)] hover:bg-[var(--color-accent-hover)] text-white font-medium text-xs transition-colors cursor-pointer">Send</button>
          </form>
          <p id="homepage-suggest-thanks" class="text-sm text-[var(--color-text-muted)] hidden">Thanks! We'll take a look.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="px-6 pb-32">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight">Ready to write?</h2>
      <p class="mt-4 text-[var(--color-text-muted)] text-lg">
        Nubium is free. No account, no trial, no strings.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-6">
        <a href="https://app.nubium.rocks" class="px-8 py-3.5 rounded-xl bg-[var(--color-accent)] hover:bg-[var(--color-accent-hover)] text-white font-semibold text-lg transition-colors no-underline">
          Try in Browser
        </a>
        <a href="/download" id="cta-download" class="text-[var(--color-accent)] hover:text-[var(--color-accent-hover)] font-medium text-lg transition-colors no-underline">
          Download for desktop
        </a>
      </div>
    </div>
  </section>

  <!-- Quick Links -->
  <section class="px-6 pb-32">
    <div class="mx-auto max-w-5xl grid sm:grid-cols-3 gap-8">
      <a href="/download" class="p-8 rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg-subtle)] hover:border-[var(--color-text-muted)] transition-colors no-underline group text-center">
        <h3 class="text-xl font-semibold group-hover:text-[var(--color-accent)] transition-colors">Download</h3>
        <p class="mt-2 text-sm text-[var(--color-text-muted)]">Get Nubium for your platform.</p>
      </a>
      <a href="https://github.com/nth-chile/nubium" class="p-8 rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg-subtle)] hover:border-[var(--color-text-muted)] transition-colors no-underline group text-center">
        <h3 class="text-xl font-semibold group-hover:text-[var(--color-accent)] transition-colors">GitHub</h3>
        <p class="mt-2 text-sm text-[var(--color-text-muted)]">Source code, issues, and roadmap.</p>
      </a>
      <a href="/community" class="p-8 rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg-subtle)] hover:border-[var(--color-text-muted)] transition-colors no-underline group text-center">
        <h3 class="text-xl font-semibold group-hover:text-[var(--color-accent)] transition-colors">Community</h3>
        <p class="mt-2 text-sm text-[var(--color-text-muted)]">Connect with other users.</p>
      </a>
    </div>
  </section>

</Layout>

<script>
  const REPO = 'nth-chile/nubium';

  function detectPlatform(): { os: string; asset: string } {
    const ua = navigator.userAgent.toLowerCase();
    const plat = (navigator as any).userAgentData?.platform?.toLowerCase() ?? navigator.platform?.toLowerCase() ?? '';

    if (plat.includes('mac') || ua.includes('macintosh')) {
      try {
        const canvas = document.createElement('canvas');
        const gl = canvas.getContext('webgl');
        if (gl) {
          const ext = gl.getExtension('WEBGL_debug_renderer_info');
          if (ext) {
            const renderer = gl.getParameter(ext.UNMASKED_RENDERER_WEBGL);
            if (renderer && renderer.includes('Apple')) {
              return { os: 'macOS', asset: 'aarch64.dmg' };
            }
          }
        }
      } catch {}
      return { os: 'macOS', asset: 'x64.dmg' };
    }
    if (plat.includes('win') || ua.includes('windows')) return { os: 'Windows', asset: 'x64-setup.exe' };
    if (plat.includes('linux') || ua.includes('linux')) return { os: 'Linux', asset: '.AppImage' };
    return { os: '', asset: '' };
  }

  const { os, asset } = detectPlatform();

  // Update button text
  if (os) {
    document.querySelectorAll('#hero-download, #cta-download').forEach(el => {
      el.textContent = `Get Nubium for ${os}`;
    });
  }

  // Resolve direct download URL from GitHub Releases
  if (asset) {
    fetch(`https://api.github.com/repos/${REPO}/releases/latest`)
      .then(r => r.ok ? r.json() : null)
      .then(release => {
        if (!release) return;
        const match = release.assets.find((a: any) =>
          a.name.includes(asset) && !a.name.endsWith('.sig') && !a.name.endsWith('.json')
        );
        if (match) {
          document.querySelectorAll<HTMLAnchorElement>('#hero-download, #cta-download').forEach(el => {
            el.href = match.browser_download_url;
          });
        }
      })
      .catch(() => {});
  }

  const hForm = document.getElementById('homepage-suggest-form') as HTMLFormElement;
  const hThanks = document.getElementById('homepage-suggest-thanks')!;

  hForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = new FormData(hForm);
    try {
      await fetch(hForm.action, { method: 'POST', body: data, headers: { Accept: 'application/json' } });
      hForm.classList.add('hidden');
      hThanks.classList.remove('hidden');
    } catch {
      hForm.submit();
    }
  });
</script>
