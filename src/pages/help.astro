<style>
  kbd {
    display: inline-block;
    padding: 0.15em 0.4em;
    font-size: 0.85em;
    font-family: inherit;
    color: var(--color-text);
    background: var(--color-bg-subtle);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    line-height: 1;
  }
  .help-nav-link.active {
    color: var(--color-text);
    border-left: 2px solid var(--color-accent);
    padding-left: 0.75rem;
  }
</style>

<script>
  const sections = document.querySelectorAll('article[id]');
  const links = document.querySelectorAll('.help-nav-link');

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        links.forEach(link => link.classList.remove('active'));
        const active = document.querySelector(`.help-nav-link[href="#${entry.target.id}"]`);
        if (active) active.classList.add('active');
      }
    });
  }, { rootMargin: '-20% 0px -70% 0px' });

  sections.forEach(section => observer.observe(section));

  // Mobile TOC toggle
  const toggle = document.getElementById('mobile-toc-toggle');
  const toc = document.getElementById('mobile-toc');
  const chevron = document.getElementById('mobile-toc-chevron');

  toggle?.addEventListener('click', () => {
    toc?.classList.toggle('hidden');
    chevron?.classList.toggle('rotate-180');
  });

  // Close mobile TOC when a link is clicked
  document.querySelectorAll('.mobile-toc-link').forEach(link => {
    link.addEventListener('click', () => {
      toc?.classList.add('hidden');
      chevron?.classList.remove('rotate-180');
    });
  });
</script>
