---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';

---

<Layout title="Download — Nubium">
  <Nav />

  <section class="pt-32 pb-20 px-6">
    <div class="mx-auto max-w-3xl text-center">
      <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight">Download Nubium</h1>
      <p class="mt-4 text-[var(--color-text-muted)] text-lg">
        Free. No account required.
      </p>

      <!-- Primary download (OS-detected later via JS) -->
      <div class="mt-12 p-8 rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg-subtle)] inline-block">
        <p class="text-sm text-[var(--color-text-muted)] mb-4" id="detected-os">Available for macOS, Windows, and Linux</p>
        <a href="#" class="inline-block px-8 py-3.5 rounded-xl bg-[var(--color-accent)] hover:bg-[var(--color-accent-hover)] text-white font-semibold text-lg transition-colors no-underline" id="primary-download">
          Download
        </a>
      </div>

      <!-- All platforms -->
      <div class="mt-16 grid sm:grid-cols-3 gap-6 text-left">
        <div class="p-6 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-subtle)]">
          <h3 class="font-semibold mb-3">macOS</h3>
          <div class="space-y-2">
            <a href="#" class="block text-sm text-[var(--color-accent)] hover:text-[var(--color-accent-hover)] no-underline">Apple Silicon (.dmg)</a>
            <a href="#" class="block text-sm text-[var(--color-accent)] hover:text-[var(--color-accent-hover)] no-underline">Intel (.dmg)</a>
          </div>
        </div>
        <div class="p-6 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-subtle)]">
          <h3 class="font-semibold mb-3">Windows</h3>
          <div class="space-y-2">
            <a href="#" class="block text-sm text-[var(--color-accent)] hover:text-[var(--color-accent-hover)] no-underline">64-bit (.msi)</a>
            <a href="#" class="block text-sm text-[var(--color-accent)] hover:text-[var(--color-accent-hover)] no-underline">ARM64 (.msi)</a>
          </div>
        </div>
        <div class="p-6 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-subtle)]">
          <h3 class="font-semibold mb-3">Linux</h3>
          <div class="space-y-2">
            <a href="#" class="block text-sm text-[var(--color-accent)] hover:text-[var(--color-accent-hover)] no-underline">AppImage</a>
            <a href="#" class="block text-sm text-[var(--color-accent)] hover:text-[var(--color-accent-hover)] no-underline">.deb (Debian/Ubuntu)</a>
          </div>
        </div>
      </div>

    </div>
  </section>

</Layout>

<script>
  const os = navigator.platform.toLowerCase();
  const el = document.getElementById('detected-os');
  const btn = document.getElementById('primary-download') as HTMLAnchorElement;
  if (os.includes('mac')) {
    if (el) el.textContent = 'Detected: macOS';
    if (btn) btn.textContent = 'Download for macOS';
  } else if (os.includes('win')) {
    if (el) el.textContent = 'Detected: Windows';
    if (btn) btn.textContent = 'Download for Windows';
  } else if (os.includes('linux')) {
    if (el) el.textContent = 'Detected: Linux';
    if (btn) btn.textContent = 'Download for Linux';
  }
</script>
